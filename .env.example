# Copiar a `.env` en la raíz del repo (`.env` está en .gitignore).
# Necesario para que arranque `apps.api.main:app` con rutas /bt2 (import de bt2_settings).

# Requerido por Bt2Settings (puede ser placeholder si no usas jobs SportMonks en esta máquina).
SPORTMONKS_API_KEY=placeholder

# PostgreSQL — misma URL que uses con Alembic (sync: postgresql://...)
BT2_DATABASE_URL=postgresql://bt2:bt2@127.0.0.1:5432/bt2_dev

# JWT BT2 (opcional en dev; hay default en código)
# BT2_SECRET_KEY=dev-secret-change-me

# --- DSR / DeepSeek (BT2 API, US-BE-025 / T-169 / D-06-018) ---
# Objetivo staging/prod: BT2_DSR_PROVIDER=deepseek + DEEPSEEK_API_KEY (picks vía modelo, adaptación v1).
# rules = solo reglas (CI / dev sin API / degradación); no es la meta de producto en entornos con PO.
# BT2_DSR_PROVIDER=rules
# BT2_DSR_PROVIDER=deepseek
# Apagar llamadas a la API DeepSeek (snapshot usa sql_stat_fallback como si DSR no hubiera devuelto picks).
# Útil mientras se alinea el modelo de datos; default en código = true.
# BT2_DSR_ENABLED=false
# Clave API (misma convención que jobs v1: jobs/deepseek_batches_to_telegram_payload_parts.py)
# DEEPSEEK_API_KEY=
# Opcionales (defaults razonables en código)
# BT2_DSR_DEEPSEEK_BASE_URL=https://api.deepseek.com
# BT2_DSR_DEEPSEEK_MODEL=deepseek-reasoner
# BT2_DSR_TIMEOUT_SEC=120
# BT2_DSR_MAX_RETRIES=1
# T-170 / D-06-019 — eventos por lote HTTP (v1-equivalente; default 15)
# BT2_DSR_BATCH_SIZE=15
# S6.1 T-177 — opcional: ids de bt2_leagues (coma-separados) para acotar pool valor.
# BT2_PRIORITY_LEAGUE_IDS=

# Opcional
# THEODDSAPI_KEY=
# Si defines WEB_API_KEY, el cliente V1 debe enviar header X-Local-Api-Key
# WEB_API_KEY=
# SQLite scrapper (default: db/sport-tracker.sqlite3)
# DB_PATH=./db/sport-tracker.sqlite3

# --- Pruebas locales BT2 (bóveda / DSR) ---
# Con 1: POST /bt2/dev/reset-operating-day-for-tests (botón «Reset día» en La Bóveda, solo DEV):
# 1) Refresca raw_sportmonks_fixtures vía SportMonks (GET fixture por id, includes = BT2_SM_FIXTURE_INCLUDES)
#    para los eventos del pool valor del día (≤20); 2) borra snapshot bóveda + desbloqueos + metadata;
# 3) cierra sesión operativa (sin DP de cierre). Requiere SPORTMONKS_API_KEY en .env.
# BT2_DEV_OPERATING_DAY_RESET=1

# --- Admin analytics DSR (NO lo genera el servidor: inventá un secreto y usá el MISMO valor en web) ---
# API: BT2_ADMIN_API_KEY=<secreto>   →  el cliente envía header X-BT2-Admin-Key con ese valor.
# Web: apps/web/.env → VITE_BT2_ADMIN_API_KEY=<mismo-secreto>   →  reiniciar npm run dev tras cambiar.
# Sin BT2_ADMIN_API_KEY en el API → 503 en GET /bt2/admin/analytics/dsr-day
# BT2_ADMIN_API_KEY=
