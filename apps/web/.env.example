# En local lo más fiable es NO poner URL del API: el front usa rutas /api/*
# y Vite las reenvía a http://127.0.0.1:8000 (mismo origen → sin problemas de CORS).
# Solo descomenta la línea siguiente si necesitas llamar al API sin proxy:
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Si en el servidor Python defines WEB_API_KEY, copia el mismo valor aquí:
# VITE_WEB_API_KEY=tu-clave-local
